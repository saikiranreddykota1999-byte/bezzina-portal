# Joseph Bezzina Portal — environment variables
# Copy to `.env.local` and fill in values.

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jbezzina.store

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
OTP_EMAIL_FROM=login@jbezzina.com
CONTACT_EMAIL_TO=
PICKUP_EMAIL_FROM=orders@jbezzina.com

# ── SMS / OTP (Twilio, optional) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_SECRET=

# ── Security (optional) ───────────────────────────────────────────────────────
# Require TOTP MFA for super_admin. Defaults to true in production, false in development.
# REQUIRE_SUPER_ADMIN_MFA=true

# ── Maps (optional) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Contact / social ─────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=+35677576721

# ── Ask Bezzina (OpenAI vision — server-only; never expose to the client) ─────
# Required for live AI replies. Without it, the widget degrades gracefully.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
ASK_BEZZINA_MODEL=gpt-4o-mini

# ── Sentry (optional — omit locally; SDK no-ops without DSN) ───────────────────
# Create a Next.js project at https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source map upload (CI/Vercel only — never commit the auth token)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ── E2E tests (optional) ───────────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# ── Demo customer seed (optional, local only — never commit real values) ─────
# DEMO_CUSTOMER_EMAIL=saikiranreddy.kota1999@gmail.com
# DEMO_CUSTOMER_PASSWORD=
# DEMO_CUSTOMER_NAME=Saikiran Reddy (Demo)

# ── Staff setup (local one-time only — NEVER commit passwords) ───────────────
# Base inbox for plus-addressed staff logins (e.g. user+admin@gmail.com)
# STAFF_BASE_EMAIL=saikiranreddy.kota1999@gmail.com
# STAFF_ADMIN_PASSWORD=
# STAFF_SALES_MANAGER_PASSWORD=
# STAFF_SALESMAN_PASSWORD=
# STAFF_WAREHOUSE_MANAGER_PASSWORD=
# STAFF_WAREHOUSE_STAFF_PASSWORD=
# STAFF_DELIVERY_DRIVER_PASSWORD=
# Run once: npm run seed:staff
