# Joseph Bezzina Portal — environment variables
# Copy to `.env.local` and fill in values.

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jbezzina.store

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
OTP_EMAIL_FROM=login@jbezzina.com
CONTACT_EMAIL_TO=
PICKUP_EMAIL_FROM=orders@jbezzina.com

# ── SMS / OTP (Twilio, optional) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_SECRET=

# ── Maps (optional) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Contact / social ─────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=+35677576721

# ── E2E tests (optional) ───────────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
